# MARK XLVI - Configuration LLM Multi-Providers
# Copiez ce fichier vers .env et ajoutez vos clés API

# ========================================
# CONFIGURATION LLM INTELLIGENTE
# ========================================

# Mode de fonctionnement: "auto" pour bascule automatique
JARVIS_LLM_PROVIDER=auto
JARVIS_LLM_MODEL=auto

# Priorité des fournisseurs (ordre de bascule)
JARVIS_LLM_PROVIDERS_PRIORITY=["nvidia", "deepseek", "gemini"]

# Configuration du router
JARVIS_LLM_AUTO_FAILOVER=true
JARVIS_LLM_TIMEOUT_SECONDS=30
JARVIS_LLM_MAX_ERRORS=3

# ========================================
# API KEYS - AJOUTEZ VOS CLÉS ICI
# ========================================

# NVIDIA API (NIM) - Priorité 1
NVIDIA_API_KEY=xxxxxxxxxxxxxxxx
JARVIS_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# DeepSeek API - Priorité 2  
DEEPSEEK_API_KEY=xxxxxxxxxxxxxxxx
JARVIS_DEEPSEEK_MODEL=deepseek/deepseek-chat

# Gemini API - Priorité 3 (fallback)
GEMINI_API_KEY=xxxxxxxxxxxxxxxx
JARVIS_GEMINI_MODEL=gemini/gemini-2.5-flash

# ========================================
# AUTRES FOURNISSEURS (OPTIONNEL)
# ========================================

# OpenAI (optionnel)
OPENAI_API_KEY=

# Anthropic (optionnel)  
ANTHROPIC_API_KEY=

# Mistral (optionnel)
MISTRAL_API_KEY=

# ========================================
# CONFIGURATION AVANCÉE
# ========================================

# Température de réponse (0.0-2.0)
JARVIS_LLM_TEMPERATURE=0.7

# Tokens maximum par réponse
JARVIS_LLM_MAX_TOKENS=

# ========================================
# AUTRES CONFIGURATIONS MARK XLVI
# ========================================

# Memory (JSON par défaut, pas de BDD requise)
JARVIS_MEMORY_BACKEND=json

# Dashboard
JARVIS_DASHBOARD_HOST=127.0.0.1
JARVIS_DASHBOARD_PORT=8000

# Logging
JARVIS_LOG_LEVEL=INFO

# Sécurité
JARVIS_REQUIRE_CONFIRMATION=true
JARVIS_SANDBOX_ENABLED=true

# Audio
JARVIS_AUDIO_SEND_SAMPLE_RATE=16000
JARVIS_AUDIO_RECEIVE_SAMPLE_RATE=24000
