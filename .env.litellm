# MARK XLVI - Configuration LiteLLM Gateway
# Migration vers provider unique LiteLLM

# ========================================
# CONFIGURATION LLM LITELLM UNIQUE
# ========================================

# Provider unique
JARVIS_LLM_PROVIDER=litellm
JARVIS_LLM_MODEL=auto

# Configuration LiteLLM Gateway
JARVIS_LITELLM_BASE_URL=http://192.168.1.198:4000
JARVIS_LITELLM_API_KEY=dummy
JARVIS_DEFAULT_MODEL=qwen-fast

# Paramètres LLM
JARVIS_LLM_TEMPERATURE=0.7
JARVIS_LLM_MAX_TOKENS=

# ========================================
# ANCIENNES VARIABLES (PLUS UTILISÉES)
# ========================================

# Ces variables ne sont plus nécessaires
# JARVIS_LLM_PROVIDERS_PRIORITY=["nvidia", "deepseek", "gemini"]
# JARVIS_LLM_AUTO_FAILOVER=true
# JARVIS_LLM_TIMEOUT_SECONDS=30
# JARVIS_LLM_MAX_ERRORS=3
# JARVIS_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# JARVIS_DEEPSEEK_MODEL=deepseek/deepseek-chat
# JARVIS_GEMINI_MODEL=gemini/gemini-2.5-flash

# Plus besoin des clés API individuelles
# NVIDIA_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# ========================================
# AUTRES CONFIGURATIONS MARK XLVI
# ========================================

# Memory (JSON par défaut)
JARVIS_MEMORY_BACKEND=json

# Dashboard
JARVIS_DASHBOARD_HOST=127.0.0.1
JARVIS_DASHBOARD_PORT=8000

# Logging
JARVIS_LOG_LEVEL=INFO

# Sécurité
JARVIS_REQUIRE_CONFIRMATION=true
JARVIS_SANDBOX_ENABLED=true

# Audio
JARVIS_AUDIO_SEND_SAMPLE_RATE=16000
JARVIS_AUDIO_RECEIVE_SAMPLE_RATE=24000

# ========================================
# MODÈLES DISPONIBLES VIA LITELLM
# ========================================

# Modèles supportés (configurés dans le gateway):
# - qwen-fast
# - deepseek-chat
# - nemotron
# - llama-3.1-8b
# - gemini-flash

# Pour changer de modèle, utilisez:
# JARVIS_DEFAULT_MODEL=nom_du_modele

# ========================================
# UTILISATION
# ========================================

# Démarrage avec LiteLLM:
# $env:JARVIS_MEMORY_BACKEND="json"; python -m jarvis.main

# Test de connexion:
# $env:JARVIS_MEMORY_BACKEND="json"; python test_litellm_mock.py
